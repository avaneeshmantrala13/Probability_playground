    {
      "id": "l7_q12",
      "kind": "challenge",
      "concept": "lln_sample_mean",
      "simulation": {
        "type": "distribution_builder",
        "shape": "normal"
      },
      "question": "X₁, …, Xₙ are i.i.d. with mean μ and finite variance. As n grows, the sample mean X̄ₙ satisfies:",
      "options": [
        "X̄ₙ converges to μ (law of large numbers)",
        "Var(X̄ₙ) stays constant in n",
        "X̄ₙ always equals μ for any finite n",
        "X̄ₙ diverges to infinity"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. The LLN says sample averages stabilize around the true mean as n increases.",
        "B": "Var(X̄ₙ) = σ²/n shrinks as n grows, it does not stay constant.",
        "C": "For finite n, random fluctuation remains; equality holds only in the limit.",
        "D": "Averages of bounded-mean variables do not diverge under the LLN assumptions."
      },
      "remediation": [
        {
          "id": "l7_q12_r1",
          "question": "If Var(X) = σ² and X̄ₙ is the mean of n i.i.d. copies, Var(X̄ₙ) equals:",
          "options": [
            "σ²/n",
            "σ²",
            "nσ²",
            "σ/√n"
          ],
          "correctAnswer": 0,
          "explanations": {
            "A": "Correct. Averaging divides variance by n.",
            "B": "σ² is the variance of one observation, not the mean.",
            "C": "nσ² multiplies instead of divides.",
            "D": "σ/√n is the standard error, not the variance."
          }
        },
        {
          "id": "l7_q12_r2",
          "question": "Monte Carlo pricing averages many simulated payoffs because the LLN guarantees:",
          "options": [
            "The sample average approximates the true expected payoff",
            "Each simulation equals the exact price",
            "Variance increases with more simulations",
            "Independence is unnecessary"
          ],
          "correctAnswer": 0,
          "explanations": {
            "A": "Correct. More independent draws make the sample mean a better estimate of E[payoff].",
            "B": "Individual simulations vary; only the average stabilizes.",
            "C": "More simulations reduce variance of the estimate, not increase it.",
            "D": "Independence (or appropriate ergodicity) is essential for the LLN logic."
          }
        }
      ]
    }
