      }
    },
    {
      "id": "pr_l15_016",
      "concept": "recurrence",
      "question": "A biased 1-D walk (p ≠ 1/2) on the unbounded line is:",
      "options": [
        "Transient (may never return)",
        "Recurrent with probability 1",
        "Always at 0",
        "Strictly periodic"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. Nonzero drift makes it transient.",
        "B": "Certain return is the symmetric case.",
        "C": "It drifts away from 0.",
        "D": "Parity does not imply recurrence."
      }
    },
    {
      "id": "pr_l15_017",
      "concept": "bet_sizing_strategy",
      "question": "Facing a negative edge and trying to double your money, the strategy that maximizes success probability is:",
      "options": [
        "Bold play (few large bets)",
        "Timid play (many small bets)",
        "It doesn't matter",
        "Never play"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. Bold play minimizes exposure to the negative drift.",
