{
  "lessonId": "lesson_16",
  "track": "quant",
  "title": "Order Statistics",
  "questions": [
    {
      "id": "pr_l16_001",
      "concept": "order_stat_definition",
      "question": "After sorting ascending, X₍₁₎ is the:",
      "options": [
        "Minimum",
        "Maximum",
        "Median",
        "Mean"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. The first sorted value is the smallest.",
        "B": "The maximum is X₍ₙ₎.",
        "C": "The median is a middle order statistic.",
        "D": "The mean is an average, not a sorted value."
      }
    },
    {
      "id": "pr_l16_002",
      "concept": "order_stat_definition",
      "question": "Sample {5, 1, 8, 3}. What is X₍₃₎?",
      "options": [
        "5",
        "3",
        "8",
        "1"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. Sorted 1,3,5,8; the 3rd smallest is 5.",
        "B": "3 is X₍₂₎.",
        "C": "8 is X₍₄₎.",
        "D": "1 is X₍₁₎."
      }
    },
    {
      "id": "pr_l16_003",
      "concept": "max_distribution",
      "question": "Two i.i.d. Uniform(0,1). P(max ≤ 0.5)?",
      "options": [
        "0.25",
        "0.5",
        "0.75",
        "0.125"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. 0.5² = 0.25.",
        "B": "0.5 is for a single draw.",
        "C": "0.75 is P(max > 0.5).",
        "D": "0.125 uses three draws."
      }
    },
    {
      "id": "pr_l16_004",
      "concept": "max_distribution",
      "question": "n i.i.d. Uniform(0,1). P(max ≤ x) equals:",
      "options": [
        "xⁿ",
        "n·x",
        "1 − xⁿ",
        "x/n"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. All n below x: F(x)ⁿ = xⁿ.",
        "B": "n·x is not a valid probability for the max.",
        "C": "1 − xⁿ is the complement.",
        "D": "x/n has no basis."
      }
    },
    {
      "id": "pr_l16_005",
      "concept": "min_distribution",
      "question": "Three i.i.d. Uniform(0,1). P(min > 0.5)?",
      "options": [
        "0.125",
        "0.25",
        "0.5",
        "0.875"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. (1 − 0.5)³ = 0.125.",
        "B": "0.25 uses two draws.",
        "C": "0.5 is a single draw.",
        "D": "0.875 = 1 − 0.125 is P(min ≤ 0.5)."
      }
    },
    {
      "id": "pr_l16_006",
      "concept": "min_distribution",
      "question": "n i.i.d. Uniform(0,1). P(min > x) equals:",
      "options": [
        "(1 − x)ⁿ",
        "xⁿ",
        "1 − xⁿ",
        "n(1 − x)"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. All n exceed x.",
        "B": "xⁿ is P(max ≤ x).",
        "C": "1 − xⁿ is P(max > x).",
        "D": "n(1 − x) is not this probability."
      }
    },
    {
      "id": "pr_l16_007",
      "concept": "expected_max_uniform",
      "question": "Three i.i.d. Uniform(0,1). E[max]?",
      "options": [
        "3/4",
        "1/2",
        "1/4",
        "2/3"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. n/(n+1) = 3/4.",
        "B": "1/2 is a single-sample mean.",
        "C": "1/4 is E[min].",
        "D": "2/3 uses n = 2."
      }
    },
    {
      "id": "pr_l16_008",
      "concept": "expected_min_uniform",
      "question": "Four i.i.d. Uniform(0,1). E[min]?",
      "options": [
        "1/5",
        "1/4",
        "4/5",
        "1/2"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. 1/(n+1) = 1/5.",
        "B": "1/4 = 1/n forgets the +1.",
        "C": "4/5 is E[max].",
        "D": "1/2 is a single-sample mean."
      }
    },
    {
      "id": "pr_l16_009",
      "concept": "kth_order_statistic",
      "question": "Five i.i.d. Uniform(0,1). E[X₍₂₎]?",
      "options": [
        "1/3",
        "2/5",
        "1/6",
        "1/2"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. k/(n+1) = 2/6 = 1/3.",
        "B": "2/5 = k/n forgets the +1.",
        "C": "1/6 is E[min].",
        "D": "1/2 is not X₍₂₎ here."
      }
    },
    {
      "id": "pr_l16_010",
      "concept": "kth_order_statistic",
      "question": "For n i.i.d. Uniform(0,1), E[X₍ₖ₎] equals:",
      "options": [
        "k/(n+1)",
        "k/n",
        "(k−1)/n",
        "n/(k+1)"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. The k-th uniform order statistic has mean k/(n+1).",
        "B": "k/n omits the +1.",
        "C": "(k−1)/n is incorrect.",
        "D": "n/(k+1) inverts the roles."
      }
    },
    {
      "id": "pr_l16_011",
      "concept": "uniform_spacings",
      "question": "Four uniform points on [0,1]. Expected length of each piece?",
      "options": [
        "1/5",
        "1/4",
        "1/3",
        "1/6"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. n+1 = 5 gaps, each 1/5.",
        "B": "1/4 forgets the extra gap.",
        "C": "1/3 is for 2 points.",
        "D": "1/6 is for 5 points."
      }
    },
    {
      "id": "pr_l16_012",
      "concept": "uniform_spacings",
      "question": "n uniform points create n+1 spacings, each of expected length:",
      "options": [
        "1/(n+1)",
        "1/n",
        "1/(n−1)",
        "n/(n+1)"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. By symmetry each of the n+1 gaps averages 1/(n+1).",
        "B": "1/n assumes n gaps.",
        "C": "1/(n−1) over-counts.",
        "D": "n/(n+1) is E[max]."
      }
    },
    {
      "id": "pr_l16_013",
      "concept": "max_discrete",
      "question": "Two fair dice. P(max = 6)?",
      "options": [
        "11/36",
        "1/6",
        "1/36",
        "25/36"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. 1 − (5/6)² = 11/36.",
        "B": "1/6 is a single die.",
        "C": "1/36 is both dice = 6.",
        "D": "25/36 is P(no 6)."
      }
    },
    {
      "id": "pr_l16_014",
      "concept": "max_discrete",
      "question": "Two fair dice. P(max ≤ 3)?",
      "options": [
        "9/36",
        "3/6",
        "1/9",
        "27/36"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. Both ≤ 3: (3/6)² = 9/36.",
        "B": "3/6 is a single die.",
        "C": "1/9 = (1/3)² mistakenly uses P(one die ≤ 3) = 1/3 instead of the correct 3/6 = 1/2.",
        "D": "27/36 = 1 − 9/36 is P(max > 3)."
      }
    },
    {
      "id": "pr_l16_015",
      "concept": "min_exponential",
      "question": "Three independent Exp(λ = 1). E[min]?",
      "options": [
        "1/3",
        "1",
        "3",
        "1/9"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. min ~ Exp(3), mean 1/3.",
        "B": "1 is a single Exp(1) mean.",
        "C": "3 is the rate of the min, not its mean.",
        "D": "1/9 has no basis."
      }
    },
    {
      "id": "pr_l16_016",
      "concept": "min_exponential",
      "question": "For n i.i.d. Exp(λ), the minimum is distributed as:",
      "options": [
        "Exp(nλ)",
        "Exp(λ/n)",
        "Exp(λ)",
        "Exp(λ + 1)"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. Rates add at the minimum.",
        "B": "Exp(λ/n) would slow the arrival, the opposite.",
        "C": "Exp(λ) is a single component.",
        "D": "Exp(λ+1) has no basis."
      }
    },
    {
      "id": "pr_l16_017",
      "concept": "range",
      "question": "Three i.i.d. Uniform(0,1). Expected range E[max − min]?",
      "options": [
        "1/2",
        "3/4",
        "1/4",
        "1"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. 3/4 − 1/4 = 1/2.",
        "B": "3/4 is E[max].",
        "C": "1/4 is E[min].",
        "D": "1 is the limiting range as n → ∞."
      }
    },
    {
      "id": "pr_l16_018",
      "concept": "median_order_statistic",
      "question": "Nine i.i.d. Uniform(0,1). Expected median (5th smallest)?",
      "options": [
        "1/2",
        "5/9",
        "4/9",
        "1/10"
      ],
      "correctAnswer": 0,
      "explanations": {
        "A": "Correct. 5/(9+1) = 1/2.",
        "B": "5/9 = k/n forgets the +1.",
        "C": "4/9 uses the wrong rank.",
        "D": "1/10 is E[min] for n = 9."
      }
    }
  ]
}
