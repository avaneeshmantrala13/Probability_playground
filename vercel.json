{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/stripe-webhook.ts": {
      "maxDuration": 30
    },
    "api/verify-checkout-session.ts": {
      "maxDuration": 30
    },
    "api/leaderboard.ts": {
      "maxDuration": 30
    },
    "api/admin-reset-progress.ts": {
      "maxDuration": 30
    },
    "api/tutor-chat.ts": {
      "maxDuration": 30
    },
    "api/poker-bot-line.ts": {
      "maxDuration": 20
    },
    "api/gym.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/poker/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
