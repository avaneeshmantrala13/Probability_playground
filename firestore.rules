rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Username -> email lookup. Readable by anyone so a username can be
    // resolved to an email at the login screen (before authentication).
    // A mapping may only be created (never overwritten) and must point at the
    // creating user. This is the Spark-plan-safe alternative to Cloud Functions.
    match /usernameMappings/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // A user's profile document.
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Theme + preferences.
    match /settings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Course progress (current lesson/question, mastery, completed lessons).
    match /courseProgress/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Per-attempt history, stored under the owning user.
    match /lessonAttempts/{uid}/attempts/{attemptId} {
      allow read, write: if isOwner(uid);
    }
  }
}
