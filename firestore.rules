rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isRoomMember(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/pokerRooms/$(roomId))
        && get(/databases/$(database)/documents/pokerRooms/$(roomId)).data.players[request.auth.uid].active == true;
    }

    function isRoomHost(roomId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/pokerRooms/$(roomId)).data.hostUid == request.auth.uid;
    }

    function isRoomPlayer() {
      return isSignedIn() && request.auth.uid in resource.data.players;
    }

    // Joining player adds themselves to players map in lobby (friends or public).
    function isJoiningLobby() {
      return isSignedIn()
        && resource.data.status == 'lobby'
        && request.auth.uid in request.resource.data.players
        && request.resource.data.players[request.auth.uid].active == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'updatedAt'])
        && (
          !(request.auth.uid in resource.data.players)
          || resource.data.players[request.auth.uid].active != true
        );
    }

    // Existing member updates only the players map (ready, chatEnabled, leave, etc.).
    function isPlayerSelfUpdate() {
      return isRoomPlayer()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'updatedAt']);
    }

    match /usernameMappings/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /settings/{uid} {
      allow read, write: if isOwner(uid);
    }

    function numMonotonic(field, maxDelta) {
      return !(field in request.resource.data)
        || (
          request.resource.data[field] is number
          && request.resource.data[field] >= 0
          && (
            !(field in resource.data)
            || request.resource.data[field] >= resource.data[field]
          )
          && (
            !(field in resource.data)
            || request.resource.data[field] <= resource.data[field] + maxDelta
          )
        );
    }

    function mentalMathFieldOk(field, maxScore) {
      return !(field in request.resource.data.mentalMathBest)
        || (
          request.resource.data.mentalMathBest[field] is number
          && request.resource.data.mentalMathBest[field] >= 0
          && request.resource.data.mentalMathBest[field] <= maxScore
          && (
            !('mentalMathBest' in resource.data)
            || !(field in resource.data.mentalMathBest)
            || request.resource.data.mentalMathBest[field] >= resource.data.mentalMathBest[field]
          )
        );
    }

    // Streak feeds the leaderboard, so cap it: it may climb by at most one per
    // write (one day at a time) and is hard-ceilinged; resets downward are fine.
    function streakUpdateOk() {
      return !('streak' in request.resource.data)
        || (
          request.resource.data.streak is number
          && request.resource.data.streak >= 0
          && request.resource.data.streak <= 3650
          && (
            !('streak' in resource.data)
            || request.resource.data.streak <= resource.data.streak + 1
          )
        );
    }

    // Plan/entitlement fields are written ONLY by the Stripe webhook (Admin SDK,
    // which bypasses these rules). Clients may never grant themselves access.
    // A field is "unchanged" when it's absent on both sides, or present on both
    // with equal values (merge writes preserve untouched fields, so normal
    // progress updates pass this unchanged).
    function fieldUnchanged(field) {
      return (
        !(field in request.resource.data) && !(field in resource.data)
      ) || (
        (field in request.resource.data)
        && (field in resource.data)
        && request.resource.data[field] == resource.data[field]
      );
    }

    function planFieldsLockedOnUpdate() {
      return fieldUnchanged('plan') && fieldUnchanged('planExpiresAt');
    }

    // On create a fresh account must be free with no paid expiry.
    function planFieldsFreshOk() {
      return (
        !('plan' in request.resource.data) || request.resource.data.plan == 'free'
      ) && (
        !('planExpiresAt' in request.resource.data)
        || request.resource.data.planExpiresAt == null
      );
    }

    function courseProgressWriteOk() {
      return numMonotonic('problemsCorrect', 25)
        && numMonotonic('lifetimeTokens', 5000)
        && streakUpdateOk()
        && planFieldsLockedOnUpdate()
        && mentalMathFieldOk('easy', 120)
        && mentalMathFieldOk('medium', 90)
        && mentalMathFieldOk('hard', 70);
    }

    // On the FIRST write a fresh account must look fresh — this blocks seeding an
    // inflated leaderboard profile (tokens/streak/problems) at creation time.
    function numMaxOnCreate(field, maxVal) {
      return !(field in request.resource.data)
        || (
          request.resource.data[field] is number
          && request.resource.data[field] >= 0
          && request.resource.data[field] <= maxVal
        );
    }

    function mentalMathCreateOk(field, maxScore) {
      return !('mentalMathBest' in request.resource.data)
        || !(field in request.resource.data.mentalMathBest)
        || (
          request.resource.data.mentalMathBest[field] is number
          && request.resource.data.mentalMathBest[field] >= 0
          && request.resource.data.mentalMathBest[field] <= maxScore
        );
    }

    function courseProgressCreateOk() {
      return numMaxOnCreate('problemsCorrect', 25)
        && numMaxOnCreate('lifetimeTokens', 1000)
        && numMaxOnCreate('tokens', 1000)
        && numMaxOnCreate('peakTokens', 1000)
        && numMaxOnCreate('streak', 1)
        && planFieldsFreshOk()
        && mentalMathCreateOk('easy', 120)
        && mentalMathCreateOk('medium', 90)
        && mentalMathCreateOk('hard', 70);
    }

    match /courseProgress/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && courseProgressCreateOk();
      allow update: if isOwner(uid) && courseProgressWriteOk();
      allow delete: if false;
    }

    // Rankings are computed server-side from courseProgress — clients read only.
    match /leaderboard/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /mentalMathLeaderboard/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /lessonAttempts/{uid}/attempts/{attemptId} {
      allow read, write: if isOwner(uid);
    }

    // Token purchases are written only by the Stripe webhook (Admin SDK).
    match /tokenPurchases/{sessionId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Room code lookup for joining friends games.
    match /roomCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.hostUid == request.auth.uid;
      allow delete: if false;
    }

    // Multiplayer poker rooms (max 6 players).
    match /pokerRooms/{roomId} {
      allow read: if isSignedIn()
        && (
          resource.data.roomType == 'public'
          || request.auth.uid in resource.data.players
          // Lobby read needed for join transaction (roomId comes from roomCodes lookup).
          || resource.data.status == 'lobby'
        );
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.maxSeats <= 6;
      allow update: if isSignedIn()
        && (
          isRoomHost(roomId)
          || isJoiningLobby()
          || isPlayerSelfUpdate()
        );
      allow delete: if isSignedIn() && isRoomHost(roomId);

      match /playerActions/{actionId} {
        allow read: if isRoomMember(roomId);
        allow create: if isRoomMember(roomId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.applied == false;
        allow update: if isRoomHost(roomId);
        allow delete: if false;
      }

      match /chat/{messageId} {
        allow read: if isRoomMember(roomId);
        allow create: if isRoomMember(roomId)
          && request.resource.data.uid == request.auth.uid
          && get(/databases/$(database)/documents/pokerRooms/$(roomId)).data.players[request.auth.uid].chatEnabled == true;
        allow update, delete: if false;
      }
    }

    // Public matchmaking queue entries (one doc per user).
    match /matchmakingQueue/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid)
        || (
          isSignedIn()
          && resource.data.status == 'waiting'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'roomId'])
          && request.resource.data.status == 'matched'
          && request.resource.data.roomId is string
        );
      allow delete: if isOwner(uid);
    }
  }
}
