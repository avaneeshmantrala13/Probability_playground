rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isRoomMember(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/pokerRooms/$(roomId))
        && get(/databases/$(database)/documents/pokerRooms/$(roomId)).data.players[request.auth.uid].active == true;
    }

    function isRoomHost(roomId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/pokerRooms/$(roomId)).data.hostUid == request.auth.uid;
    }

    function isRoomPlayer() {
      return isSignedIn() && request.auth.uid in resource.data.players;
    }

    // Joining player adds themselves to players map in lobby (friends or public).
    function isJoiningLobby() {
      return isSignedIn()
        && resource.data.status == 'lobby'
        && request.auth.uid in request.resource.data.players
        && request.resource.data.players[request.auth.uid].active == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'updatedAt'])
        && (
          !(request.auth.uid in resource.data.players)
          || resource.data.players[request.auth.uid].active != true
        );
    }

    // Existing member updates only the players map (ready, chatEnabled, leave, etc.).
    function isPlayerSelfUpdate() {
      return isRoomPlayer()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'updatedAt']);
    }

    match /usernameMappings/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /settings/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /courseProgress/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Public ranking stats — each player writes only their own row.
    match /leaderboard/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.lifetimeTokens is number
        && request.resource.data.streak is number
        && request.resource.data.problemsCorrect is number;
      allow delete: if false;
    }

    match /mentalMathLeaderboard/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.bestEasy is number
        && request.resource.data.bestMedium is number
        && request.resource.data.bestHard is number;
      allow delete: if false;
    }

    match /lessonAttempts/{uid}/attempts/{attemptId} {
      allow read, write: if isOwner(uid);
    }

    // Token purchases are written only by the Stripe webhook (Admin SDK).
    match /tokenPurchases/{sessionId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Room code lookup for joining friends games.
    match /roomCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.hostUid == request.auth.uid;
      allow delete: if false;
    }

    // Multiplayer poker rooms (max 6 players).
    match /pokerRooms/{roomId} {
      allow read: if isSignedIn()
        && (
          resource.data.roomType == 'public'
          || request.auth.uid in resource.data.players
          // Lobby read needed for join transaction (roomId comes from roomCodes lookup).
          || resource.data.status == 'lobby'
        );
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.maxSeats <= 6;
      allow update: if isSignedIn()
        && (
          isRoomHost(roomId)
          || isJoiningLobby()
          || isPlayerSelfUpdate()
        );
      allow delete: if isSignedIn() && isRoomHost(roomId);

      match /playerActions/{actionId} {
        allow read: if isRoomMember(roomId);
        allow create: if isRoomMember(roomId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.applied == false;
        allow update: if isRoomHost(roomId);
        allow delete: if false;
      }

      match /chat/{messageId} {
        allow read: if isRoomMember(roomId);
        allow create: if isRoomMember(roomId)
          && request.resource.data.uid == request.auth.uid
          && get(/databases/$(database)/documents/pokerRooms/$(roomId)).data.players[request.auth.uid].chatEnabled == true;
        allow update, delete: if false;
      }
    }

    // Public matchmaking queue entries (one doc per user).
    match /matchmakingQueue/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid)
        || (
          isSignedIn()
          && resource.data.status == 'waiting'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'roomId'])
          && request.resource.data.status == 'matched'
          && request.resource.data.roomId is string
        );
      allow delete: if isOwner(uid);
    }
  }
}
